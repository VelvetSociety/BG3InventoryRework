<ls:UIWidget x:Name="InventoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ls="clr-namespace:ls;assembly=Code"
             xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <ls:UIWidget.Resources>
        <ResourceDictionary>
            <!-- ── Real BG3 inventory textures ────────────────────── -->
            <BitmapImage x:Key="ContainerBg"
                         UriSource="pack://application:,,,/Core;component/Assets/Container/container_background.png"/>
            <BitmapImage x:Key="CharPanelBg"
                         UriSource="pack://application:,,,/Core;component/Assets/CharacterPanel/genericFaded_bg.png"/>
            <BitmapImage x:Key="SlotBg"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared/slot_inventory.png"/>
            <BitmapImage x:Key="CloseBtnD"
                         UriSource="pack://application:,,,/Core;component/Assets/Container/container_closeBtn_d.png"/>
            <BitmapImage x:Key="CloseBtnH"
                         UriSource="pack://application:,,,/Core;component/Assets/Container/container_closeBtn_h.png"/>
            <BitmapImage x:Key="RoundBtnD"
                         UriSource="pack://application:,,,/Core;component/Assets/Container/container_roundBtn_d.png"/>
            <BitmapImage x:Key="RoundBtnH"
                         UriSource="pack://application:,,,/Core;component/Assets/Container/container_roundBtn_h.png"/>
            <BitmapImage x:Key="PanelBg"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_panel_bg.png"/>
            <BitmapImage x:Key="SlotHighlight"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared/invSlot_selector.png"/>
            <BitmapImage x:Key="TooltipBg"
                         UriSource="pack://application:,,,/Core;component/Assets/Tooltips/TT_full_bg.png"/>
            <BitmapImage x:Key="SearchInputD"
                         UriSource="pack://application:,,,/Core;component/Assets/Lobby/input_directCode_d.png"/>
            <BitmapImage x:Key="SearchInputH"
                         UriSource="pack://application:,,,/Core;component/Assets/Lobby/input_directCode_h.png"/>
            <BitmapImage x:Key="RefreshIconD"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_refresh_d.png"/>
            <BitmapImage x:Key="RefreshIconH"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared/ico_refresh_h.png"/>

            <!-- ── Filter panel checkbox assets ─────────────────── -->
            <BitmapImage x:Key="CheckOff"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_checkHolder_d.DDS"/>
            <BitmapImage x:Key="CheckOffH"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_checkHolder_h.DDS"/>
            <BitmapImage x:Key="CheckOn"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_checkHolder_active_d.DDS"/>
            <BitmapImage x:Key="CheckOnH"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_checkHolder_active_h.DDS"/>
            <BitmapImage x:Key="CheckMark"
                         UriSource="pack://application:,,,/Core;component/Assets/Shared_c/c_checkmark.DDS"/>

            <!-- ── Filter panel colours ─────────────────────────── -->
            <SolidColorBrush x:Key="FilterSectionHeader" Color="#FFc8b88a"/>
            <SolidColorBrush x:Key="FilterText"          Color="#FFd4cfc0"/>
            <SolidColorBrush x:Key="FilterActiveChip"    Color="#44c8b88a"/>
            <SolidColorBrush x:Key="FilterInactiveChip"  Color="#22FFFFFF"/>
            <SolidColorBrush x:Key="SortActiveBg"        Color="#44c8b88a"/>

            <!-- ── Rarity colours ─────────────────────────────────── -->
            <SolidColorBrush x:Key="RarityCommon"    Color="#AAAAAA"/>
            <SolidColorBrush x:Key="RarityUncommon"  Color="#1EFF00"/>
            <SolidColorBrush x:Key="RarityRare"      Color="#0070FF"/>
            <SolidColorBrush x:Key="RarityVeryRare"  Color="#A335EE"/>
            <SolidColorBrush x:Key="RarityLegendary" Color="#FF8000"/>

            <!-- ── Close button template with hover ───────────────── -->
            <ControlTemplate x:Key="CloseButtonTemplate" TargetType="Button">
                <Grid>
                    <Image x:Name="btnImg" Source="{StaticResource CloseBtnD}"
                           Stretch="None"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="btnImg" Property="Source"
                                Value="{StaticResource CloseBtnH}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- ── Round button template with hover ───────────────── -->
            <ControlTemplate x:Key="RoundButtonTemplate" TargetType="Button">
                <Grid>
                    <Image x:Name="btnBg" Source="{StaticResource RoundBtnD}"
                           Stretch="None"/>
                    <TextBlock Text="{TemplateBinding Content}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="White" FontSize="12"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="btnBg" Property="Source"
                                Value="{StaticResource RoundBtnH}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- ── Native context menu assets ──────────────────────── -->
            <BitmapImage x:Key="CtxMenuBg"
                         UriSource="pack://application:,,,/Core;component/Assets/ContextMenu/contextMenu_bg.png"/>
            <BitmapImage x:Key="CtxItemFrame"
                         UriSource="pack://application:,,,/Core;component/Assets/ContextMenu/contextMenu_itemFrame.png"/>
            <BitmapImage x:Key="CtxItemSelector"
                         UriSource="pack://application:,,,/Core;component/Assets/ContextMenu/contextMenu_itemSelector.png"/>

            <!-- BG3 context menu text colour (warm cream) -->
            <SolidColorBrush x:Key="CtxTextColor" Color="#FFd4cfc0"/>
            <SolidColorBrush x:Key="CtxHeaderColor" Color="#FFc8b88a"/>

            <!-- ── Context menu item — native BG3 nine-slice + hover ──── -->
            <ControlTemplate x:Key="ContextMenuBtnTemplate" TargetType="Button">
                <ls:LSNineSliceImage x:Name="bg"
                                     ImageSource="{StaticResource CtxItemFrame}"
                                     Slices="48,40,48,1" Padding="6,4,6,4"
                                     MinHeight="48">
                    <TextBlock x:Name="label" Text="{TemplateBinding Content}"
                               Foreground="{StaticResource CtxTextColor}"
                               FontSize="24" VerticalAlignment="Center"
                               Margin="8,0,8,0"/>
                </ls:LSNineSliceImage>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bg" Property="ImageSource"
                                Value="{StaticResource CtxItemSelector}"/>
                        <Setter TargetName="label" Property="Foreground" Value="White"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- ── Item card — icon cell with native BG3 tooltip ──────── -->
            <DataTemplate x:Key="ItemCardTemplate">
                <ls:LSEntityObject Margin="2" Cursor="Hand"
                                   Background="Transparent"
                                   EntityRef="{Binding GameItemEntityHandle}"
                                   ls:TooltipExtender.Owner="{Binding SelectedChar,
                                       RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"
                                   ToolTipService.Placement="Right"
                                   ToolTipService.InitialShowDelay="200"
                                   ToolTipService.IsEnabled="{Binding HasGameItem}">
                    <ls:LSEntityObject.ToolTip>
                        <ToolTip Style="{x:Null}"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 HasDropShadow="False">
                            <ls:LSTooltip Content="{Binding GameItem}"
                                          PlayerId="{Binding (ls:UIWidget.PlayerId), ElementName=InventoryPanel}"/>
                        </ToolTip>
                    </ls:LSEntityObject.ToolTip>

                    <Grid Width="96" Height="96">
                        <Image Source="{StaticResource SlotBg}" Stretch="Fill"/>
                        <Image Source="{Binding Icon}" Stretch="Uniform" Margin="6"/>
                        <Rectangle Fill="{Binding GameItemBrush}" Stretch="Uniform" Margin="6"/>
                    </Grid>
                </ls:LSEntityObject>
            </DataTemplate>

            <!-- ── Item cell style — left-click selects, right-click opens menu ── -->
            <Style x:Key="NativeTooltipTestStyle" TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <!-- Outer grid: root of the template. DataContext = wrapper (INVRW_SlotWrapper).
                                 CellRoot overrides DataContext to NativeObject for icon/tooltip bindings.
                                 StackBadge is a sibling of CellRoot so it keeps wrapper as DataContext
                                 and can bind {Binding StackSize} directly without RelativeSource hacks. -->
                            <Grid Width="96" Height="96">
                                <ls:LSEntityObject x:Name="CellRoot"
                                                   DataContext="{Binding NativeObject}"
                                                   EntityRef="{Binding DataContext.NativeHandle,
                                                       RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                   Background="Transparent"
                                                   ToolTipService.Placement="Right">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="MouseRightButtonDown">
                                            <b:InvokeCommandAction
                                                Command="{Binding DataContext.ShowMenuCommand,
                                                    RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                                        </b:EventTrigger>
                                        <b:EventTrigger EventName="MouseLeftButtonDown">
                                            <b:InvokeCommandAction
                                                Command="{Binding DataContext.HideMenuCommand,
                                                    RelativeSource={RelativeSource AncestorType={x:Type ls:UIWidget}}}"/>
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                    <ls:LSEntityObject.ToolTip>
                                        <ls:LSTooltip Content="{Binding DataContext.NativeObject,
                                            RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                            CanBePinned="True"/>
                                    </ls:LSEntityObject.ToolTip>
                                    <Grid Width="96" Height="96">
                                        <Image Source="{StaticResource SlotBg}" Stretch="Fill"/>
                                        <!-- Rarity background glow (behind icon) — shown by DataTrigger -->
                                        <Image x:Name="RarityFrameBack"
                                               Stretch="Fill" Visibility="Collapsed"
                                               IsHitTestVisible="False"/>
                                        <Rectangle Fill="{Binding Icon}" Stretch="Uniform" Margin="6"/>
                                        <!-- Rarity foreground frame (on top of icon) — shown by DataTrigger -->
                                        <Image x:Name="RarityFrameFront"
                                               Stretch="Fill" Visibility="Collapsed"
                                               IsHitTestVisible="False"/>
                                        <!-- Selection highlight overlay -->
                                        <Image x:Name="SelectionHighlight"
                                               Source="{StaticResource SlotHighlight}"
                                               Stretch="Fill" Visibility="Collapsed"/>
                                    </Grid>
                                </ls:LSEntityObject>
                                <!-- Stack badge — outside CellRoot so DataContext = wrapper.
                                     {Binding StackSize} reads wrapper.StackSize (aggregated total). -->
                                <Viewbox x:Name="StackBadge" Visibility="Collapsed"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         StretchDirection="DownOnly"
                                         MaxWidth="56" MaxHeight="32"
                                         IsHitTestVisible="False">
                                    <TextBlock Text="{Binding StackSize}"
                                               Foreground="White" FontSize="32" FontWeight="Bold"
                                               noesis:Text.Stroke="#FF000000"
                                               noesis:Text.StrokeThickness="8"
                                               Margin="4,0"/>
                                </Viewbox>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="SelectionHighlight"
                                            Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="SelectionHighlight"
                                            Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <!-- Rarity back glow -->
                                <DataTrigger Binding="{Binding Rarity}" Value="Uncommon">
                                    <Setter TargetName="RarityFrameBack" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_uncommon_back.png"/>
                                    <Setter TargetName="RarityFrameBack" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rarity}" Value="Rare">
                                    <Setter TargetName="RarityFrameBack" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_rare_back.png"/>
                                    <Setter TargetName="RarityFrameBack" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rarity}" Value="VeryRare">
                                    <Setter TargetName="RarityFrameBack" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_veryrare_back.png"/>
                                    <Setter TargetName="RarityFrameBack" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rarity}" Value="Legendary">
                                    <Setter TargetName="RarityFrameBack" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_legendary_back.png"/>
                                    <Setter TargetName="RarityFrameBack" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- Rarity front frame -->
                                <DataTrigger Binding="{Binding Rarity}" Value="Uncommon">
                                    <Setter TargetName="RarityFrameFront" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_uncommon_front.png"/>
                                    <Setter TargetName="RarityFrameFront" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rarity}" Value="Rare">
                                    <Setter TargetName="RarityFrameFront" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_rare_front.png"/>
                                    <Setter TargetName="RarityFrameFront" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rarity}" Value="VeryRare">
                                    <Setter TargetName="RarityFrameFront" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_veryrare_front.png"/>
                                    <Setter TargetName="RarityFrameFront" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rarity}" Value="Legendary">
                                    <Setter TargetName="RarityFrameFront" Property="Source"
                                            Value="pack://application:,,,/Core;component/Assets/Shared/rarityFrame_legendary_front.png"/>
                                    <Setter TargetName="RarityFrameFront" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- Stack badge visibility -->
                                <DataTrigger Binding="{Binding ShowStack}" Value="True">
                                    <Setter TargetName="StackBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Filter checkbox template ───────────────────────── -->
            <!-- Uses Tag="{Binding FilterXxx}" to drive checked/unchecked visuals.
                 Command binding set on each Button via Content for the label text. -->
            <ControlTemplate x:Key="FilterCheckboxTemplate" TargetType="Button">
                <Grid Margin="2,3" Cursor="Hand">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Checkbox image -->
                    <Grid Grid.Column="0" Width="24" Height="24" VerticalAlignment="Center">
                        <Image x:Name="chkBg" Source="{StaticResource CheckOff}" Stretch="Uniform"/>
                        <Image x:Name="chkMark" Source="{StaticResource CheckMark}" Stretch="Uniform"
                               Visibility="Collapsed"/>
                    </Grid>
                    <!-- Label -->
                    <TextBlock Grid.Column="1" Text="{TemplateBinding Content}"
                               Foreground="{StaticResource FilterText}"
                               FontSize="20" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="chkBg" Property="Source"
                                Value="{StaticResource CheckOffH}"/>
                    </Trigger>
                    <!-- Tag="True" means checked -->
                    <Trigger Property="Tag" Value="True">
                        <Setter TargetName="chkBg" Property="Source"
                                Value="{StaticResource CheckOn}"/>
                        <Setter TargetName="chkMark" Property="Visibility" Value="Visible"/>
                    </Trigger>
                    <!-- Hover when checked -->
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="Tag" Value="True"/>
                            <Condition Property="IsMouseOver" Value="True"/>
                        </MultiTrigger.Conditions>
                        <Setter TargetName="chkBg" Property="Source"
                                Value="{StaticResource CheckOnH}"/>
                    </MultiTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- ── Filter chip template (compact pill for slots) ──── -->
            <ControlTemplate x:Key="FilterChipTemplate" TargetType="Button">
                <Border x:Name="chipBorder" CornerRadius="12"
                        Background="{StaticResource FilterInactiveChip}"
                        Padding="10,4" Margin="2,2" Cursor="Hand">
                    <TextBlock Text="{TemplateBinding Content}"
                               Foreground="{StaticResource FilterText}"
                               FontSize="18" HorizontalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="chipBorder" Property="Background"
                                Value="{StaticResource FilterActiveChip}"/>
                    </Trigger>
                    <Trigger Property="Tag" Value="True">
                        <Setter TargetName="chipBorder" Property="Background"
                                Value="{StaticResource FilterActiveChip}"/>
                        <Setter TargetName="chipBorder" Property="BorderBrush"
                                Value="{StaticResource FilterSectionHeader}"/>
                        <Setter TargetName="chipBorder" Property="BorderThickness" Value="1"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>


        </ResourceDictionary>
    </ls:UIWidget.Resources>

    <!-- Full-screen canvas — NO IsHitTestVisible (empty canvas is click-transparent) -->
    <Canvas x:Name="Root">

        <!-- The inventory panel — uses BG3's character panel background -->
        <ls:LSNineSliceImage x:Name="PanelRoot"
                Canvas.Left="310" Canvas.Top="80"
                Width="{Binding PanelWidth}" Height="{Binding PanelHeight}"
                ImageSource="{StaticResource CharPanelBg}"
                Slices="52"
                Padding="24,20,24,16">

            <b:Interaction.Behaviors>
                <b:MouseDragElementBehavior/>
            </b:Interaction.Behaviors>

            <Grid Background="Transparent">
                <!-- Left-click anywhere on the panel closes the context menu -->
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="MouseLeftButtonUp">
                        <b:InvokeCommandAction Command="{Binding HideMenuCommand}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <!-- Input binding for tooltip pinning (K key) -->
                <ls:LSInputBinding Style="{DynamicResource PinTooltipBindingStyle}"/>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── Row 0 : Header / drag handle ────────────────── -->
                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="Combined Inventory"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#E6DBC2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Filter toggle button -->
                        <Button Command="{Binding ToggleFilterPanelCommand}"
                                Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="48" Height="48">
                                        <Image x:Name="filterBg"
                                               Source="{StaticResource RoundBtnD}"
                                               Stretch="Uniform"/>
                                        <TextBlock x:Name="filterIco" Text="&#x2630;"
                                                   Foreground="White" FontSize="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <!-- Active filter count badge -->
                                        <Border x:Name="filterBadge"
                                                Background="#CC8B0000" CornerRadius="8"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,-4,-4,0"
                                                Padding="4,1"
                                                MinWidth="16">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveFilterCount}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding ActiveFilterCount}"
                                                       Foreground="White" FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="filterBg" Property="Source"
                                                    Value="{StaticResource RoundBtnH}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding FilterPanelVisible}" Value="True">
                                            <Setter TargetName="filterBg" Property="Source"
                                                    Value="{StaticResource RoundBtnH}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Close button -->
                        <Button Template="{StaticResource CloseButtonTemplate}"
                                Command="{Binding ToggleCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- ── Row 1 : Search bar (Lua-driven keyboard input) ──── -->
                <Button Grid.Row="1" Grid.Column="0" Margin="0,0,0,8"
                        Command="{Binding SearchFocusCommand}"
                        Cursor="IBeam" HorizontalContentAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ls:LSNineSliceImage x:Name="InputBg"
                                ImageSource="{StaticResource SearchInputD}"
                                Slices="40,16,40,16" Padding="40,12,16,12"
                                MinHeight="48">
                                <DockPanel>
                                    <!-- X clear button — only visible when there's text -->
                                    <Button x:Name="ClearBtn" DockPanel.Dock="Right"
                                            Command="{Binding ClearSearchCommand}"
                                            Width="32" Height="32"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0"
                                            Visibility="Collapsed">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Image x:Name="xBg"
                                                           Source="{StaticResource RoundBtnD}"
                                                           Stretch="Uniform"/>
                                                    <TextBlock Text="X"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="White" FontSize="12"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="xBg" Property="Source"
                                                                Value="{StaticResource RoundBtnH}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="{Binding SearchQuery}"
                                               Foreground="{StaticResource CtxTextColor}"
                                               FontSize="28" VerticalAlignment="Center"
                                               MinHeight="32"/>
                                </DockPanel>
                            </ls:LSNineSliceImage>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="InputBg" Property="ImageSource"
                                            Value="{StaticResource SearchInputH}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding HasSearchQuery}" Value="True">
                                    <Setter TargetName="ClearBtn" Property="Visibility"
                                            Value="Visible"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- ── Row 2 : Item grid (native ListBox hierarchy) ───── -->
                <Border Grid.Row="2" Grid.Column="0" ls:TooltipExtender.Owner="{Binding SelectedChar}">
                    <Grid>
                        <ListBox ItemsSource="{Binding NativeSlots}"
                                 ItemContainerStyle="{StaticResource NativeTooltipTestStyle}"
                                 SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 SelectionMode="Single"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <!-- ── Right-click context menu overlay ─────────── -->
                        <!-- Uses native BG3 contextMenu_bg nine-slice + item frames.
                             Positioned via Lua. Visible only when ShowMenuCommand fires. -->
                        <Canvas x:Name="MenuLayer" IsHitTestVisible="False">
                            <Border x:Name="ContextMenuPanel"
                                    Canvas.Left="{Binding MenuX}"
                                    Canvas.Top="{Binding MenuY}"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="True">
                                <ls:LSNineSliceImage ImageSource="{StaticResource CtxMenuBg}"
                                                     Slices="50" Padding="24,32,24,24">
                                    <StackPanel>
                                        <!-- Item name header -->
                                        <TextBlock Text="{Binding SelectedItemName}"
                                                   Foreground="{StaticResource CtxHeaderColor}"
                                                   FontSize="24" FontWeight="SemiBold"
                                                   Margin="10,0,10,6"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="260"/>
                                        <!-- Actions -->
                                        <Button Content="Use"
                                                Template="{StaticResource ContextMenuBtnTemplate}"
                                                Command="{Binding UseItemCommand}"/>
                                        <Button Content="Equip"
                                                Template="{StaticResource ContextMenuBtnTemplate}"
                                                Command="{Binding EquipItemCommand}"/>
                                        <Button Content="Drop"
                                                Template="{StaticResource ContextMenuBtnTemplate}"
                                                Command="{Binding DropItemCommand}"/>
                                        <Button Content="Send to Camp"
                                                Template="{StaticResource ContextMenuBtnTemplate}"
                                                Command="{Binding SendToCampCommand}"/>
                                    </StackPanel>
                                </ls:LSNineSliceImage>
                            </Border>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- ── Row 3 : Status bar + refresh + resize grip ──── -->
                <DockPanel Grid.Row="3" Grid.Column="0" Margin="12,4,12,4">
                    <!-- Resize controls — rightmost -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0,0,0">
                        <!-- Width label + buttons -->
                        <TextBlock Text="W" Foreground="#88E6DBC2" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button Command="{Binding NarrowCommand}"
                                Cursor="Hand" Margin="0,0,2,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="36" Height="36">
                                        <Image x:Name="bg" Source="{StaticResource RoundBtnD}"
                                               Stretch="Uniform"/>
                                        <TextBlock Text="&#x25C0;" Foreground="White" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Source"
                                                    Value="{StaticResource RoundBtnH}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding WidenCommand}"
                                Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="36" Height="36">
                                        <Image x:Name="bg" Source="{StaticResource RoundBtnD}"
                                               Stretch="Uniform"/>
                                        <TextBlock Text="&#x25B6;" Foreground="White" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Source"
                                                    Value="{StaticResource RoundBtnH}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Height label + buttons -->
                        <TextBlock Text="H" Foreground="#88E6DBC2" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button Command="{Binding ResizeShrinkCommand}"
                                Cursor="Hand" Margin="0,0,2,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="36" Height="36">
                                        <Image x:Name="bg" Source="{StaticResource RoundBtnD}"
                                               Stretch="Uniform"/>
                                        <TextBlock Text="-" Foreground="White" FontSize="22"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Source"
                                                    Value="{StaticResource RoundBtnH}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ResizeGrowCommand}"
                                Cursor="Hand" Margin="2,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Width="36" Height="36">
                                        <Image x:Name="bg" Source="{StaticResource RoundBtnD}"
                                               Stretch="Uniform"/>
                                        <TextBlock Text="+" Foreground="White" FontSize="22"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Source"
                                                    Value="{StaticResource RoundBtnH}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Refresh button — next to scaler -->
                    <Button DockPanel.Dock="Right"
                            Command="{Binding RefreshCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="ico" Source="{StaticResource RefreshIconD}"
                                       Stretch="Uniform" Width="36" Height="36"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ico" Property="Source"
                                                Value="{StaticResource RefreshIconH}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Status text — fills remaining space -->
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="18" Foreground="#E6DBC2"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- ── Column 1 : Filter Panel (slides out from right) ── -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Border Grid.Column="1" Grid.RowSpan="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilterPanelVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <ls:LSNineSliceImage ImageSource="{StaticResource CharPanelBg}"
                                         Slices="52" Width="360" Padding="24,16,24,16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="8,12,8,4">

                                <!-- ── Filter Header ──────────────────────── -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Filters"
                                               Foreground="{StaticResource FilterSectionHeader}"
                                               FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Button Command="{Binding ClearAllFiltersCommand}"
                                            Cursor="Hand"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,4,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="clearBg" CornerRadius="4"
                                                        Background="Transparent"
                                                        Padding="6,3">
                                                    <TextBlock Text="Clear"
                                                               Foreground="{StaticResource FilterText}"
                                                               FontSize="16"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="clearBg"
                                                                Property="Background"
                                                                Value="{StaticResource FilterInactiveChip}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- ── Sort By ────────────────────────────── -->
                                <TextBlock Text="Sort By"
                                           Foreground="{StaticResource FilterSectionHeader}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Margin="0,4,0,4"/>
                                <WrapPanel Orientation="Horizontal">
                                    <!-- Name -->
                                    <Button Command="{Binding SortByNameCommand}"
                                            Tag="{Binding SortState_Name}"
                                            Cursor="Hand" Margin="2,2">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="sb" CornerRadius="4"
                                                        Background="Transparent"
                                                        Padding="8,4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Name"
                                                                   Foreground="{StaticResource FilterText}"
                                                                   FontSize="18"/>
                                                        <TextBlock x:Name="arrow" Text=""
                                                                   Foreground="{StaticResource FilterSectionHeader}"
                                                                   FontSize="16" Margin="4,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource FilterInactiveChip}"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Desc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25B2;"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Asc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25BC;"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- Value -->
                                    <Button Command="{Binding SortByValueCommand}"
                                            Tag="{Binding SortState_Value}"
                                            Cursor="Hand" Margin="2,2">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="sb" CornerRadius="4"
                                                        Background="Transparent"
                                                        Padding="8,4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Value"
                                                                   Foreground="{StaticResource FilterText}"
                                                                   FontSize="18"/>
                                                        <TextBlock x:Name="arrow" Text=""
                                                                   Foreground="{StaticResource FilterSectionHeader}"
                                                                   FontSize="16" Margin="4,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource FilterInactiveChip}"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Desc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25B2;"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Asc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25BC;"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- Weight -->
                                    <Button Command="{Binding SortByWeightCommand}"
                                            Tag="{Binding SortState_Weight}"
                                            Cursor="Hand" Margin="2,2">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="sb" CornerRadius="4"
                                                        Background="Transparent"
                                                        Padding="8,4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Weight"
                                                                   Foreground="{StaticResource FilterText}"
                                                                   FontSize="18"/>
                                                        <TextBlock x:Name="arrow" Text=""
                                                                   Foreground="{StaticResource FilterSectionHeader}"
                                                                   FontSize="16" Margin="4,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource FilterInactiveChip}"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Desc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25B2;"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Asc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25BC;"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- Rarity -->
                                    <Button Command="{Binding SortByRarityCommand}"
                                            Tag="{Binding SortState_Rarity}"
                                            Cursor="Hand" Margin="2,2">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="sb" CornerRadius="4"
                                                        Background="Transparent"
                                                        Padding="8,4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Rarity"
                                                                   Foreground="{StaticResource FilterText}"
                                                                   FontSize="18"/>
                                                        <TextBlock x:Name="arrow" Text=""
                                                                   Foreground="{StaticResource FilterSectionHeader}"
                                                                   FontSize="16" Margin="4,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource FilterInactiveChip}"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Desc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25B2;"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="Asc">
                                                        <Setter TargetName="sb" Property="Background"
                                                                Value="{StaticResource SortActiveBg}"/>
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25BC;"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </WrapPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="#33FFFFFF" Margin="0,8"/>

                                <!-- ── Item Type ──────────────────────────── -->
                                <TextBlock Text="Item Type"
                                           Foreground="{StaticResource FilterSectionHeader}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Margin="0,4,0,4"/>
                                <StackPanel>
                                    <Button Content="Weapon"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleType_Weapon}"
                                            Tag="{Binding FilterType_Weapon}"/>
                                    <Button Content="Armor"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleType_Armor}"
                                            Tag="{Binding FilterType_Armor}"/>
                                    <Button Content="Consumable"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleType_Consumable}"
                                            Tag="{Binding FilterType_Consumable}"/>
                                    <Button Content="Scroll"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleType_Scroll}"
                                            Tag="{Binding FilterType_Scroll}"/>
                                    <Button Content="Container"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleType_Container}"
                                            Tag="{Binding FilterType_Container}"/>
                                    <Button Content="Book"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleType_Book}"
                                            Tag="{Binding FilterType_Book}"/>
                                    <Button Content="Misc"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleType_Misc}"
                                            Tag="{Binding FilterType_Misc}"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="#33FFFFFF" Margin="0,8"/>

                                <!-- ── Rarity ─────────────────────────────── -->
                                <TextBlock Text="Rarity"
                                           Foreground="{StaticResource FilterSectionHeader}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Margin="0,4,0,4"/>
                                <StackPanel>
                                    <Button Content="Common"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleRarity_Common}"
                                            Tag="{Binding FilterRarity_Common}"/>
                                    <Button Content="Uncommon"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleRarity_Uncommon}"
                                            Tag="{Binding FilterRarity_Uncommon}"/>
                                    <Button Content="Rare"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleRarity_Rare}"
                                            Tag="{Binding FilterRarity_Rare}"/>
                                    <Button Content="Very Rare"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleRarity_VeryRare}"
                                            Tag="{Binding FilterRarity_VeryRare}"/>
                                    <Button Content="Legendary"
                                            Template="{StaticResource FilterCheckboxTemplate}"
                                            Command="{Binding ToggleRarity_Legendary}"
                                            Tag="{Binding FilterRarity_Legendary}"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="#33FFFFFF" Margin="0,8"/>

                                <!-- ── Equipment Slot ─────────────────────── -->
                                <TextBlock Text="Equipment Slot"
                                           Foreground="{StaticResource FilterSectionHeader}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Margin="0,4,0,4"/>
                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="Helmet"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Helmet}"
                                            Tag="{Binding FilterSlot_Helmet}"/>
                                    <Button Content="Chest"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Chest}"
                                            Tag="{Binding FilterSlot_Chest}"/>
                                    <Button Content="Cloak"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Cloak}"
                                            Tag="{Binding FilterSlot_Cloak}"/>
                                    <Button Content="Gloves"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Gloves}"
                                            Tag="{Binding FilterSlot_Gloves}"/>
                                    <Button Content="Boots"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Boots}"
                                            Tag="{Binding FilterSlot_Boots}"/>
                                    <Button Content="Amulet"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Amulet}"
                                            Tag="{Binding FilterSlot_Amulet}"/>
                                    <Button Content="Ring"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Ring}"
                                            Tag="{Binding FilterSlot_Ring}"/>
                                    <Button Content="Main Hand"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_MainHand}"
                                            Tag="{Binding FilterSlot_MainHand}"/>
                                    <Button Content="Off Hand"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_OffHand}"
                                            Tag="{Binding FilterSlot_OffHand}"/>
                                    <Button Content="Ranged"
                                            Template="{StaticResource FilterChipTemplate}"
                                            Command="{Binding ToggleSlot_Ranged}"
                                            Tag="{Binding FilterSlot_Ranged}"/>
                                </WrapPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </ls:LSNineSliceImage>
                </Border>

            </Grid>
        </ls:LSNineSliceImage>

    </Canvas>

</ls:UIWidget>
