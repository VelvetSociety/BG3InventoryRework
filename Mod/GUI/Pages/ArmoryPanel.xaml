                                            <Button x:Name="ClearBtn" DockPanel.Dock="Right"
                                                    Command="{Binding ClearSearchCommand}"
                                                    Width="32" Height="32"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0"
                                                    Visibility="Collapsed">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Image x:Name="xBg"
                                                                   Source="{StaticResource RoundBtnD}"
                                                                   Stretch="Uniform"/>
