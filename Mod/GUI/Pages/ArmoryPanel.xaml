                                                                       FontSize="22"/>
                                                            <TextBlock x:Name="sortArrow" Text=""
                                                                       Foreground="{StaticResource FilterSectionHeader}"
                                                                       FontSize="20" Margin="4,0,0,0"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="sortBorder" Property="Background" Value="{StaticResource FilterInactiveChip}"/>
                                                        </Trigger>
                                                        <Trigger Property="Tag" Value="Desc">
                                                            <Setter TargetName="sortBorder" Property="Background" Value="{StaticResource SortActiveBg}"/>
                                                            <Setter TargetName="sortArrow" Property="Text" Value="&#x25B2;"/>
                                                        </Trigger>
                                                        <Trigger Property="Tag" Value="Asc">
                                                            <Setter TargetName="sortBorder" Property="Background" Value="{StaticResource SortActiveBg}"/>
                                                            <Setter TargetName="sortArrow" Property="Text" Value="&#x25BC;"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
