                                                    Tag="{Binding FilterAC_13to15}"/>
                                            <Button Content="16+"
                                                    Template="{StaticResource FilterChipTemplate}"
                                                    Command="{Binding ToggleAC_16plus}"
                                                    Tag="{Binding FilterAC_16plus}"/>
                                        </WrapPanel>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Border>
                </Grid>

                <!-- Slot picker popup overlay — visible only when SlotPickerVisible = true -->
                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                      Background="#88000000">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SlotPickerVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <!-- Centered popup card -->
                    <ls:LSNineSliceImage HorizontalAlignment="Center" VerticalAlignment="Center"
                                         ImageSource="{StaticResource CharPanelBg}"
                                         Slices="52" Padding="32,24">
                        <StackPanel MinWidth="280">
                            <!-- Title -->
                            <TextBlock Text="{Binding SlotPickerTitle}"
                                       Foreground="{StaticResource FilterSectionHeader}"
                                       FontSize="26" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <!-- Option 1 -->
                            <Button Content="{Binding SlotPickerOpt1}"
                                    Command="{Binding SlotPickerOpt1Command}"
                                    Cursor="Hand" Margin="0,0,0,8">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="optBorder1" CornerRadius="6"
                                                Background="{StaticResource SlotChipInactive}"
                                                BorderBrush="{StaticResource SlotChipBorder}"
                                                BorderThickness="1" Padding="16,10">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       Foreground="{StaticResource FilterText}"
                                                       FontSize="26" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="optBorder1" Property="Background"
                                                        Value="{StaticResource SlotChipActive}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Option 2 -->
                            <Button Content="{Binding SlotPickerOpt2}"
                                    Command="{Binding SlotPickerOpt2Command}"
                                    Cursor="Hand" Margin="0,0,0,16">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="optBorder2" CornerRadius="6"
                                                Background="{StaticResource SlotChipInactive}"
                                                BorderBrush="{StaticResource SlotChipBorder}"
                                                BorderThickness="1" Padding="16,10">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       Foreground="{StaticResource FilterText}"
                                                       FontSize="26" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="optBorder2" Property="Background"
                                                        Value="{StaticResource SlotChipActive}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Cancel -->
                            <Button Content="Cancel"
                                    Command="{Binding SlotPickerCancelCommand}"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cancelBorder" CornerRadius="6"
                                                Background="Transparent" Padding="16,6">
                                            <TextBlock Text="Cancel"
                                                       Foreground="#FF888888"
                                                       FontSize="22" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cancelBorder" Property="Background"
                                                        Value="#22FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </ls:LSNineSliceImage>
                </Grid>

                <!-- Status bar -->
                <Grid Grid.Row="2" Margin="10,8,10,6">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#88FFFFFF" FontSize="22"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Command="{Binding RefreshCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="refIcon"
                                       Source="{StaticResource RefreshIconD}"
                                       Width="32" Height="32"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="refIcon" Property="Source"
                                                Value="{StaticResource RefreshIconH}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </Grid>
        </ls:LSNineSliceImage>
    </Canvas>
</ls:UIWidget>
