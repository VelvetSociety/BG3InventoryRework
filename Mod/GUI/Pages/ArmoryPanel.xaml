                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Damage Type"
                                                   Foreground="{StaticResource FilterSectionHeader}"
                                                   FontSize="22" FontWeight="SemiBold"
