                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </Border>
                    </Grid>
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- ── Column 2 : Filter Panel (slides out from right) ── -->
                    <!-- ═══════════════════════════════════════════════════════ -->
