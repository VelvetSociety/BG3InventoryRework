                                    <!-- Separator -->
                                    <Border Height="2.5" Background="#33FFFFFF" Margin="0,8"/>

                                    <!-- ── Damage Dice (Weapons / All only) ───── -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FilterSection_DamageDice}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Damage Dice"
                                                   Foreground="{StaticResource FilterSectionHeader}"
                                                   FontSize="22" FontWeight="SemiBold"
                                                   Margin="0,4,0,4"/>
