                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Image Source="pack://application:,,,/Core;component/Assets/Shared/ico_dmg_slashing.png"
                                                           Width="24" Height="24" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Slashing" Foreground="{StaticResource FilterText}" FontSize="24" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Width="210" Template="{StaticResource FilterDmgTypeTemplate}"
                                                    Command="{Binding ToggleDmgType_Piercing}"
                                                    Tag="{Binding FilterDmgType_Piercing}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Image Source="pack://application:,,,/Core;component/Assets/Shared/ico_dmg_piercing.png"
                                                           Width="24" Height="24" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Piercing" Foreground="{StaticResource FilterText}" FontSize="24" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Width="210" Template="{StaticResource FilterDmgTypeTemplate}"
                                                    Command="{Binding ToggleDmgType_Bludgeoning}"
                                                    Tag="{Binding FilterDmgType_Bludgeoning}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Image Source="pack://application:,,,/Core;component/Assets/Shared/ico_dmg_blunt.png"
                                                           Width="24" Height="24" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
