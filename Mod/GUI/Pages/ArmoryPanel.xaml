                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterPanelVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Border Background="#28c8b88a" CornerRadius="0"
                                BorderBrush="#66c8b88a" BorderThickness="2.5,0,0,0"
                                Width="490" Padding="24,20,10,20">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="12,12,12,4">

                                    <!-- ── Filter Header ──────────────────────── -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Filters"
