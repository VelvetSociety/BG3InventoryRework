                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Button Command="{Binding ClearAllFiltersCommand}"
                                                Cursor="Hand"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,4,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="clearBg" CornerRadius="4"
                                                            Background="Transparent"
                                                            Padding="6,3">
                                                        <TextBlock Text="Clear"
                                                                   Foreground="{StaticResource FilterText}"
                                                                   FontSize="20"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="clearBg"
                                                                    Property="Background"
                                                                    Value="{StaticResource FilterInactiveChip}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- ── Sort By ────────────────────────────── -->
                                    <TextBlock Text="Sort By"
                                               Foreground="{StaticResource FilterSectionHeader}"
                                               FontSize="22" FontWeight="SemiBold"
                                               Margin="0,4,0,4"/>
