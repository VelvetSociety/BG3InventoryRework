<ls:StateMachine xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ls="clr-namespace:ls;assembly=Code">
    <ls:StateMachine.States>
        <ls:State Name="PlayerHUD" ModType="Extend">
            <ls:State.Widgets>
                <ls:StateWidget Filename="InventoryPanel.xaml" Layer="HUD"/>
                <ls:StateWidget Filename="ArmoryPanel.xaml" Layer="HUD"/>
            </ls:State.Widgets>
        </ls:State>
    </ls:StateMachine.States>
</ls:StateMachine>
